android_app_import {
    name: "MIUICamera",
    apk: "MiuiCamera.apk",
    privileged: true,
    presigned: true,
    compile_multilib: "64",
    dex_preopt: { enabled: false },
    preprocessed: true,
    required: [
        "MIUICamera_libSNPE",
        "MIUICamera_libcamera_algoup_jni",
        "MIUICamera_libsnpe_dsp_domains_v2",
        "MIUICamera_libsnpe_dsp_skel",
        "MIUICamera_libsnpe_dsp_v65_domains_v2_skel",
        "MIUICamera_libsnpe_dsp_v66_domains_v2_skel",
        "MIUICamera_libsymphony_cpu",
        "MIUICamera_libmiocr_wrapper",
    ],
    overrides: ["Camera2", "Aperture"],
}

android_app_import {
    name: "MiuiExtraPhoto",
    owner: "xiaomi",
    apk: "MiuiExtraPhoto.apk",
    privileged: true,
    presigned: true,
    compile_multilib: "64",
    dex_preopt: { enabled: false },
    preprocessed: true,
    required: [
        "ExtraPhoto_libauto_crop_cpp_shared",
        "ExtraPhoto_libautocrop",
        "ExtraPhoto_libcommon",
        "ExtraPhoto_libcpp_shared",
        "ExtraPhoto_libdoc_photo_cpp_shared",
