        "ExtraPhoto_libgallery_mpbase",
        "ExtraPhoto_libmegvii_bokeh_jni",
        "ExtraPhoto_libmialgo_ai_vision",
        "ExtraPhoto_libmialgo_autocrop",
        "ExtraPhoto_libmialgo_portrait",
        "ExtraPhoto_libmialgo_utils_extraphoto",
        "ExtraPhoto_libmialgo_utils",
        "ExtraPhoto_libmibokeh_gallery",
        "ExtraPhoto_libmibrain_relighting_jni",
        "ExtraPhoto_libmicamera_dual_bokeh_jni",
        "ExtraPhoto_libmiphone_bokeh_dynSpot",
        "ExtraPhoto_libmiphone_bokeh_effect",
        "ExtraPhoto_libmiphone_bokeh_gpf",
        "ExtraPhoto_libmiphone_bokeh_proc",
        "ExtraPhoto_libmiphone_refocus_bokeh",
        "ExtraPhoto_libmisr",
        "ExtraPhoto_libmiuiblursdk",
        "ExtraPhoto_libMNN",
        "ExtraPhoto_libmotion_photo_cpp_shared",
        "ExtraPhoto_libmotion_photo_mace",
        "ExtraPhoto_libmotion_photo",
        "ExtraPhoto_librefocus_meitu",
        "ExtraPhoto_librefocus_mibokeh",
        "ExtraPhoto_librefocus",
        "ExtraPhoto_libselection",
        "ExtraPhoto_libwa_refocus_extraphoto",
        "ExtraPhoto_libxcrash_dumper",
        "ExtraPhoto_libxcrash",
        "ExtraPhoto_libyuv",
    ],
}

